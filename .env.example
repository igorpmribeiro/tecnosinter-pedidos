DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=10"
# Use a direct (non-pooled) connection for `prisma db push` / `prisma migrate`.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Random string with at least 32 chars. Generate with:
#   openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string-of-32-plus-chars"

# Optional: override the seed admin (defaults: admin@tecnosinter.com / admin12345)
SEED_ADMIN_EMAIL="admin@tecnosinter.com"
SEED_ADMIN_NAME="Administrador"
SEED_ADMIN_PASSWORD="admin12345"
